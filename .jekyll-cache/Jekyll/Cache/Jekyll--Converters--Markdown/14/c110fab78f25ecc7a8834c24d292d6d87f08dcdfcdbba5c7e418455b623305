        <span class="nx">gulp</span><span class="p">.</span><span class="nx">src</span><span class="p">(</span><span class="nx">path</span><span class="p">.</span><span class="nx">join</span><span class="p">(</span><span class="nx">buildPath</span><span class="p">,</span> <span class="nx">folder</span><span class="p">,</span> <span class="dl">'</span><span class="s1">*.html</span><span class="dl">'</span><span class="p">))</span>
