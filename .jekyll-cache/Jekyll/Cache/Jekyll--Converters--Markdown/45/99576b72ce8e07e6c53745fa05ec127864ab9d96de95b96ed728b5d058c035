  <span class="na">date</span><span class="p">:</span> <span class="k">new</span> <span class="nb">Date</span><span class="p">(),</span>
  <span class="na">userInfo</span><span class="p">:</span> <span class="p">{</span>
    <span class="na">name</span><span class="p">:</span> <span class="dl">"</span><span class="s2">Better</span><span class="dl">"</span><span class="p">,</span>
    <span class="na">position</span><span class="p">:</span> <span class="dl">"</span><span class="s2">front-end engineer</span><span class="dl">"</span><span class="p">,</span>
    <span class="na">skill</span><span class="p">:</span> <span class="p">[</span><span class="dl">"</span><span class="s2">React</span><span class="dl">"</span><span class="p">,</span> <span class="dl">"</span><span class="s2">Vue</span><span class="dl">"</span><span class="p">,</span> <span class="dl">"</span><span class="s2">Angular</span><span class="dl">"</span><span class="p">,</span> <span class="dl">"</span><span class="s2">Nodejs</span><span class="dl">"</span><span class="p">,</span> <span class="dl">"</span><span class="s2">mini programs</span><span class="dl">"</span><span class="p">],</span>
  <span class="p">},</span>
  <span class="na">func</span><span class="p">:</span> <span class="kd">function</span> <span class="p">()</span> <span class="p">{</span>
    <span class="nx">console</span><span class="p">.</span><span class="nx">log</span><span class="p">(</span><span class="dl">"</span><span class="s2">hello better</span><span class="dl">"</span><span class="p">);</span>
