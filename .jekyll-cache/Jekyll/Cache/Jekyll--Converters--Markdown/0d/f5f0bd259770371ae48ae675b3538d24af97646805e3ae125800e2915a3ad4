<span class="nx">console</span><span class="p">.</span><span class="nx">log</span><span class="p">(</span><span class="nx">formatOrderNo1</span><span class="p">);</span> <span class="c1">// 6666 6666 6666 6666 666</span>

<span class="c1">// з»“еҗҲдҪҝз”Ёе…ҲиЎҢж–ӯиЁҖе’ҢеҗҺеҸ‘ж–ӯиЁҖ</span>
<span class="kd">var</span> <span class="nx">res</span> <span class="o">=</span> <span class="dl">"</span><span class="s2">6230 6666 6666 8851</span><span class="dl">"</span><span class="p">.</span><span class="nx">replace</span><span class="p">(</span><span class="sr">/</span><span class="se">(?&lt;</span><span class="sr">=</span><span class="se">\s</span><span class="sr">+</span><span class="se">)(\d{4})(?=\s</span><span class="sr">+</span><span class="se">)</span><span class="sr">/g</span><span class="p">,</span> <span class="dl">'</span><span class="s1">****</span><span class="dl">'</span><span class="p">);</span>
<span class="nx">console</span><span class="p">.</span><span class="nx">log</span><span class="p">(</span><span class="nx">res</span><span class="p">);</span> <span class="c1">// 6230 **** **** 8851</span>
