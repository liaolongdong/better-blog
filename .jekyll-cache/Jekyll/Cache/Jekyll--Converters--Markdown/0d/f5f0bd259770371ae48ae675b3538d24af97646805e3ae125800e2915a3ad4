<span class="kd">var</span> <span class="nx">formatBankNo</span> <span class="o">=</span> <span class="nx">bankNo</span><span class="p">.</span><span class="nx">replace</span><span class="p">(</span><span class="sr">/</span><span class="se">\B(?&lt;</span><span class="sr">=</span><span class="se">(?&lt;</span><span class="sr">!</span><span class="se">\d)(\d{4})</span><span class="sr">+</span><span class="se">)</span><span class="sr">/g</span><span class="p">,</span> <span class="dl">'</span><span class="s1"> </span><span class="dl">'</span><span class="p">);</span>
<span class="c1">// var formatOrderNo = orderNo.replace(/\B(?&lt;=(?&lt;!\d)(\d{4})+)/g, ' ');</span>
<span class="kd">var</span> <span class="nx">formatOrderNo</span> <span class="o">=</span> <span class="nx">orderNo</span><span class="p">.</span><span class="nx">replace</span><span class="p">(</span><span class="sr">/....</span><span class="se">(?!</span><span class="sr">$</span><span class="se">)</span><span class="sr">/g</span><span class="p">,</span> <span class="dl">'</span><span class="s1">$&amp; </span><span class="dl">'</span><span class="p">);</span>
<span class="kd">var</span> <span class="nx">formatOrderNo1</span> <span class="o">=</span> <span class="nx">orderNo1</span><span class="p">.</span><span class="nx">replace</span><span class="p">(</span><span class="sr">/</span><span class="se">(\d{4}(?=\d))</span><span class="sr">/g</span><span class="p">,</span> <span class="dl">'</span><span class="s1">$1 </span><span class="dl">'</span><span class="p">);</span>

<span class="nx">console</span><span class="p">.</span><span class="nx">log</span><span class="p">(</span><span class="nx">formatBankNo</span><span class="p">);</span> <span class="c1">// 8888 8888 8888 8888</span>
