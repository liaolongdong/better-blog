<h2 id="з”ЁдёҖиЎҢд»Јз Ғе®һзҺ°дёҖдёӘз®Җжҳ“зҡ„жЁЎжқҝеӯ—з¬ҰдёІеҠҹиғҪ">з”ЁдёҖиЎҢд»Јз Ғе®һзҺ°дёҖдёӘз®Җжҳ“зҡ„жЁЎжқҝеӯ—з¬ҰдёІеҠҹиғҪ</h2>

<div class="language-js highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="nb">String</span><span class="p">.</span><span class="nx">prototype</span><span class="p">.</span><span class="nx">render</span> <span class="o">=</span> <span class="kd">function</span> <span class="p">(</span><span class="nx">context</span><span class="p">)</span> <span class="p">{</span>
    <span class="k">return</span> <span class="k">this</span><span class="p">.</span><span class="nx">replace</span><span class="p">(</span><span class="sr">/</span><span class="se">\{\{(</span><span class="sr">.*</span><span class="se">?)\}\}</span><span class="sr">/g</span><span class="p">,</span> <span class="p">(</span><span class="nx">match</span><span class="p">,</span> <span class="nx">key</span><span class="p">)</span> <span class="o">=&gt;</span> <span class="nx">context</span><span class="p">[</span><span class="nx">key</span><span class="p">.</span><span class="nx">trim</span><span class="p">()]);</span>
<span class="p">};</span>

<span class="c1">// з”ЁжҲ·дҝЎжҒҜеҜ№иұЎ</span>
<span class="kd">var</span> <span class="nx">userInfo</span> <span class="o">=</span> <span class="p">{</span>
    <span class="na">name</span><span class="p">:</span> <span class="dl">'</span><span class="s1">Better</span><span class="dl">'</span><span class="p">,</span>
