    <span class="nx">player4</span> <span class="o">=</span> <span class="nx">playerFactory</span><span class="p">(</span><span class="dl">'</span><span class="s1">小强</span><span class="dl">'</span><span class="p">,</span> <span class="dl">'</span><span class="s1">red</span><span class="dl">'</span><span class="p">);</span>
<span class="c1">// 蓝队</span>
<span class="kd">var</span> <span class="nx">player5</span> <span class="o">=</span> <span class="nx">playerFactory</span><span class="p">(</span><span class="dl">'</span><span class="s1">黑妞</span><span class="dl">'</span><span class="p">,</span> <span class="dl">'</span><span class="s1">blue</span><span class="dl">'</span><span class="p">),</span>
    <span class="nx">player6</span> <span class="o">=</span> <span class="nx">playerFactory</span><span class="p">(</span><span class="dl">'</span><span class="s1">葱头</span><span class="dl">'</span><span class="p">,</span> <span class="dl">'</span><span class="s1">blue</span><span class="dl">'</span><span class="p">),</span>
