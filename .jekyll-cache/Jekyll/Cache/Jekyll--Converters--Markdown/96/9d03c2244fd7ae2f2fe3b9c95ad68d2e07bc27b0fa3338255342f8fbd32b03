<span class="kd">var</span> <span class="nx">player1</span> <span class="o">=</span> <span class="nx">playerFactory</span><span class="p">(</span><span class="dl">'</span><span class="s1">皮蛋</span><span class="dl">'</span><span class="p">,</span> <span class="dl">'</span><span class="s1">red</span><span class="dl">'</span><span class="p">),</span>
