    <span class="nx">player8</span> <span class="o">=</span> <span class="nx">playerFactory</span><span class="p">(</span><span class="dl">'</span><span class="s1">海盗</span><span class="dl">'</span><span class="p">,</span> <span class="dl">'</span><span class="s1">blue</span><span class="dl">'</span><span class="p">);</span>
